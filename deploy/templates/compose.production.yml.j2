services:
  web:
    image: "{{ docker_image }}"
    container_name: "{{ container_name }}"
    restart: unless-stopped
    ports:
      - "{{ app_bind_address }}:{{ app_host_port }}:3000"
    environment:
      NODE_ENV: production
      PORT: "3000"
      HOSTNAME: "0.0.0.0"
      VERSION: "{{ app_version }}"
      MET_USER_AGENT: "{{ met_user_agent }}"
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          node -e "require('http').get('http://127.0.0.1:3000/api/health', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"
      interval: 30s
      timeout: 10s
      start_period: 40s
      retries: 3
    logging:
      driver: json-file
      options:
        max-size: 10m
        max-file: "3"
